<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Para mi Princesita ❤️</title>

<style> 
body { 
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', cursive;
    color: white;
    text-align: center;
    background: url("Snoopy.jpg") no-repeat center center fixed;
    background-size: cover;
    overflow-x: hidden;
}

/* 🌌 ESTRELLAS */
#estrellas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
}

/* TITULO */
.titulo-animado {
    color: red;
    -webkit-text-stroke: 1px black;
    opacity: 0;
    transform: translateX(-100px);
    animation: aparecerIzq 2s forwards;
}

@keyframes aparecerIzq {
    to { opacity: 1; transform: translateX(0); }
}

/* BOTON */
.start-btn {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 85%;
    max-width: 420px;
    padding: 25px;
    background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("Snoopy.jpg");
    background-size: cover;
    background-position: center;
    color: white;
    font-size: 18px;
    border-radius: 20px;
    cursor: pointer;
    z-index: 9999;
    box-shadow: 0 0 25px rgba(255,0,0,0.7);
    border: 2px solid red;
}

/* CONTENIDO */
#contenido {
    display: none;
    animation: fade 2s;
}

@keyframes fade {
    from {opacity:0;}
    to {opacity:1;}
}

.container {
    display: flex;
    justify-content: space-around;
    padding: 20px;
}

.box {
    width: 40%;
    background: rgba(0,0,0,0.4);
    padding: 20px;
    border-radius: 15px;
}

.video-box {
    width: 40%;
}

/* CONTADOR */
#contador {
    margin-top: 10px;
    font-size: 20px;
    color: red;
    font-weight: bold;
    text-shadow: 0 0 10px red;
}

/* GALERIA */
.gallery {
    width: 300px;
    height: 300px;
    margin: 30px auto;
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}

.gallery img {
    position: absolute;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 1.5s;
}

.gallery img.active {
    opacity: 1;
}

/* PARTICULAS */
.particle {
    position: fixed;
    top: -10%;
    animation: caer linear infinite;
}

@keyframes caer {
    100% { transform: translateY(110vh) rotate(360deg); }
}

/* TE AMO INFINITO */
.infinito {
    font-size: 30px;
    margin-top: 40px;
    color: red;
    animation: latido 1s infinite;
}

@keyframes latido {
    0% { transform: scale(1); }
    50% { transform: scale(1.2); }
    100% { transform: scale(1); }
}
</style>
</head>

<body>

<canvas id="estrellas"></canvas>

<div class="start-btn" onclick="iniciar()">
🖤 Feliz mesiversario mi princesita, toca aquí 😉 🖤
</div>

<audio id="musica" loop preload="auto">
  <source src="Cancion.mp3" type="audio/mpeg">
</audio>

<div id="contenido">

<h1 id="titulo" class="titulo-animado"></h1>
<div id="contador"></div>

<div class="gallery">
  <img src="imagen1.jpeg">
  <img src="imagen2.jpeg">
  <img src="imagen3.jpeg">
  <img src="imagen4.jpeg">
  <img src="imagen5.jpeg">
  <img src="imagen6.jpeg">
  <img src="imagen7.jpeg">
  <img src="imagen8.jpeg">
  <img src="imagen9.jpeg">
  <img src="imagen10.jpeg">
  <img src="imagen11.jpeg">
</div>

<div class="container">

    <div class="box">
        <p id="text1"></p>
        <p id="text2"></p>
    </div>

    <div class="video-box">
        <video id="video" controls width="100%">
            <source src="video.mp4" type="video/mp4">
        </video>
    </div>

</div>

<div class="infinito">Te amo infinito ♾️</div>

<button onclick="mostrarSecreto()" style="margin-top:20px; padding:10px; border-radius:10px;">
💌 Mensaje secreto
</button>

<div id="secreto" style="display:none; margin-top:20px; color:red;">
✨ (Shhh, no le digas a mi Ochi que la adoro, que quiero que se me cuide mucho y que se lave el pupo. Ella es lo más valioso que tengo; amo a mi chiquita con olor a patitas.) ✨
</div>

</div>

<script>
// 🌌 ESTRELLAS RESPONSIVE
const canvas = document.getElementById("estrellas");
const ctx = canvas.getContext("2d");

function resizeCanvas(){
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
}
resizeCanvas();
window.addEventListener("resize", resizeCanvas);

let stars = Array.from({length:100}, ()=>({
    x: Math.random()*canvas.width,
    y: Math.random()*canvas.height,
    size: Math.random()*2,
    speed: Math.random()*0.5
}));

function animarEstrellas(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    stars.forEach(s=>{
        ctx.fillStyle="white";
        ctx.fillRect(s.x,s.y,s.size,s.size);
        s.y += s.speed;
        if(s.y > canvas.height){
            s.y = 0;
            s.x = Math.random()*canvas.width;
        }
    });
    requestAnimationFrame(animarEstrellas);
}
animarEstrellas();

// TEXTOS
let texto1=`Hoy cumplimos otro mes juntos ❤️`;
let texto2=`Mi cielo, mi vida entera... 🌻✨
Hoy, mientras el mundo sigue girando a mil por hora, me detuve un instante y me puse a pensar en nuestra historia. 45 meses... casi cuatro años, mi amor. 
Y se me eriza la piel al pensar que no ha pasado ni un solo día en el que no agradezca haberte encontrado. Hemos pasado por días de sol brillante y otros donde el cielo se nos caía encima, pero mírame, 
aquí sigo, con el corazón intacto y más enamorado que el primer día, porque incluso en medio de cualquier tormenta, tú siempre has sido mi calma, mi puerto, mi lugar seguro en este universo tan loco.
Sé que a veces soy tu terremoto, que te hago reír cuando menos te lo esperas o que me paso de molestoso, pero es que me maravilla la mujer que tengo al lado. No tienes idea de cómo admiro tu fuerza, 
la pasión que le pones a cada cosa que haces. Me derrito viéndote ser tú, con esa esencia única, con esa ternura que, aunque a veces es silenciosa, yo la siento vibrar en cada detalle, en cada mirada, 
(adoro esos ojitos) en cada gesto que tienes conmigo. Gracias por abrirme las puertas de tu mundo, por confiar en mí y, sobre todo, por elegirme un mes más para caminar de mi mano, para ser tu cómplice y tu compañero de vida.
No quiero perfección, mi flaca. Quiero tu risa, tus dudas, tus ganas de comerte al mundo y también tus días de bajón, donde lo único que quiero es ser el refugio donde te escondes. Aquí voy a estar siempre: 
para arroparte cuando haga frío, para darte esos masajitos en tus patitas cansadas, y para decirte al oído cada vez que lo necesites que eres, sin duda alguna, la mujer más increíble, berraca y hermosa que mis ojos hayan visto jamás.
Felices 45 meses, mi vida. Gracias por existir, por ser mi motor y por hacerme el hombre más afortunado de esta tierra solo por tenerte. Te amo de una forma que no me cabe en el pecho, con todo lo que soy y con todo lo que tengo. ❤️
`;

// MESES
function calcularMeses(){
    let inicio=new Date(2022,5,6);
    let hoy=new Date();
    let total=(hoy.getFullYear()-inicio.getFullYear())*12+(hoy.getMonth()-inicio.getMonth());
    if(hoy.getDate()<inicio.getDate()) total--;
    return total;
}

// CONTADOR
function actualizarContador(){
    let inicio=new Date(2022,5,6);
    let diff=new Date()-inicio;

    let dias=Math.floor(diff/(1000*60*60*24));
    let horas=Math.floor((diff/(1000*60*60))%24);
    let min=Math.floor((diff/(1000*60))%60);
    let seg=Math.floor((diff/1000)%60);

    document.getElementById("contador").innerHTML=
    `${dias} días ${horas}h ${min}m ${seg}s ❤️`;
}

// ESCRIBIR
function escribir(id,texto){
    let i=0;
    let el=document.getElementById(id);
    (function t(){
        if(i<texto.length){
            el.innerHTML+=texto[i++];
            setTimeout(t,20);
        }
    })();
}

// PARTICULAS
function crearParticulas(){
    let emojis=["🌻","🌹","🐣","🥰"];
    for(let i=0;i<40;i++){
        let e=document.createElement("div");
        e.className="particle";
        e.innerHTML=emojis[Math.floor(Math.random()*emojis.length)];
        e.style.left=Math.random()*100+"vw";
        e.style.fontSize=(15+Math.random()*20)+"px";
        e.style.animationDuration=(6+Math.random()*6)+"s";
        document.body.appendChild(e);
    }
}

// GALERIA
function iniciarGaleria(){
    let index=0;
    let images=document.querySelectorAll(".gallery img");

    function cambiar(){
        images.forEach(img=>img.classList.remove("active"));
        images[index].classList.add("active");
        index=(index+1)%images.length;
    }

    cambiar();
    setInterval(cambiar,3000);
}

// AUDIO FIX PRO
function fadeInAudio(audio){
    audio.muted = false;
    audio.volume = 0;

    let playPromise = audio.play();

    if(playPromise){
        playPromise.then(()=>{
            let v=0;
            let i=setInterval(()=>{
                if(v<1){
                    v+=0.02;
                    audio.volume=v;
                } else clearInterval(i);
            },200);
        }).catch(()=>{
            alert("Toca otra vez para activar el sonido ❤️");
        });
    }
}

function controlarAudioVideo(){
    let audio = document.getElementById("musica");
    let video = document.getElementById("video");

    if(video && audio){

        video.addEventListener("play", () => {
            if(!audio.paused){
                audio.pause();
            }
        });

        video.addEventListener("pause", () => {
            fadeInAudio(audio);
        });

        video.addEventListener("ended", () => {
            fadeInAudio(audio);
        });
    }
}

// VIBRACION
function vibrarCorazon(){
    if(navigator.vibrate){
        navigator.vibrate([200,100,200,100,400]);
    }
}

// MENSAJE
function mostrarSecreto(){
    document.getElementById("secreto").style.display="block";
}

// INICIO
function iniciar(){
    document.querySelector(".start-btn").style.display="none";
    document.getElementById("contenido").style.display="block";

    vibrarCorazon();

    document.getElementById("titulo").innerHTML=
    "Feliz "+calcularMeses()+" meses juntos ❤️";

    let audio = document.getElementById("musica");
audio.muted = false;
fadeInAudio(audio);

controlarAudioVideo();

    crearParticulas();
    escribir("text1",texto1);
    setTimeout(()=>escribir("text2",texto2),2000);
    iniciarGaleria();

    actualizarContador();
    setInterval(actualizarContador,1000);
}
</script>

</body>
</html>
