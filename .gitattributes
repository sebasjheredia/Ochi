<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Para mi Princesita ❤️</title>
 
<style>
body {
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', cursive;
    color: white;
    text-align: center;
    background: url("Snoopy.jpg") no-repeat center center fixed;
    background-size: cover;
    overflow-x: hidden;
}

/* TITULO */
.titulo-animado {
    color: red;
    -webkit-text-stroke: 1px black;
    opacity: 0;
    transform: translateX(-100px);
    animation: aparecerIzq 2s forwards;
}

@keyframes aparecerIzq {
    to { opacity: 1; transform: translateX(0); }
}

/* BOTON */
.start-btn {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 85%;
    max-width: 420px;
    padding: 25px;
    background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("Snoopy.jpg");
    background-size: cover;
    background-position: center;
    color: white;
    font-size: 18px;
    border-radius: 20px;
    cursor: pointer;
    z-index: 9999;
    box-shadow: 0 0 25px rgba(255,0,0,0.7);
    border: 2px solid red;
}

/* CONTENIDO */
#contenido {
    display: none;
    animation: fade 2s;
}

@keyframes fade {
    from {opacity:0;}
    to {opacity:1;}
}

.container {
    display: flex;
    justify-content: space-around;
    padding: 20px;
}

.box {
    width: 40%;
    background: rgba(0,0,0,0.4);
    padding: 20px;
    border-radius: 15px;
}

.video-box {
    width: 40%;
}

/* CONTADOR */
#contador {
    margin-top: 10px;
    font-size: 18px;
    color: #ffcccc;
}

/* GALERIA */
.gallery {
    width: 300px;
    height: 300px;
    margin: 30px auto;
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}

.gallery img {
    position: absolute;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 1.5s;
}

.gallery img.active {
    opacity: 1;
}

/* PARTICULAS */
.particle {
    position: fixed;
    top: -10%;
    animation: caer linear infinite;
}

@keyframes caer {
    100% { transform: translateY(110vh) rotate(360deg); }
}

/* TE AMO INFINITO */
.infinito {
    font-size: 30px;
    margin-top: 40px;
    color: red;
    animation: latido 1s infinite;
}

@keyframes latido {
    0% { transform: scale(1); }
    50% { transform: scale(1.2); }
    100% { transform: scale(1); }
}

/* RESPONSIVE */
@media (max-width:768px){
    .container {
        flex-direction: column;
        align-items: center;
    }
    .box, .video-box {
        width: 90%;
        margin-bottom: 20px;
    }
}
</style>
</head>

<body>

<div class="start-btn" onclick="iniciar()">
🖤 Feliz mesiversario mi princesita, toca aquí 😉 🖤
</div>

<audio id="musica" loop>
  <source src="I love you song.mp3" type="audio/mpeg">
</audio>

<div id="contenido">

<h1 id="titulo" class="titulo-animado"></h1>
<div id="contador"></div>

<div class="gallery">
  <img src="imagen1.jpeg">
  <img src="imagen2.jpeg">
  <img src="imagen3.jpeg">
  <img src="imagen4.jpeg">
  <img src="imagen5.jpeg">
  <img src="imagen6.jpeg">
  <img src="imagen7.jpeg">
  <img src="imagen8.jpeg">
</div>

<div class="container">

    <div class="box">
        <p id="text1"></p>
        <p id="text2"></p>
    </div>

    <div class="video-box">
        <video id="video" controls width="100%">
            <source src="video.mp4" type="video/mp4">
        </video>
    </div>

</div>

<div class="infinito">Te amo infinito ♾️</div>

</div>

<script>
// TEXTOS
let texto1 = `Hoy cumplimos otro mes más juntos ❤️
y no sabes lo feliz que soy de tenerte en mi vida...`;

let texto2 = `Gracias por todo mi amor 🖤 Te amo muchísimo.`;

// CALCULAR MESES
function calcularMeses(){
    let inicio = new Date(2022, 5, 6);
    let hoy = new Date();

    let total = (hoy.getFullYear()-inicio.getFullYear())*12 +
                (hoy.getMonth()-inicio.getMonth());

    if(hoy.getDate() < inicio.getDate()) total--;
    return total;
}

// CONTADOR TIEMPO REAL
function actualizarContador(){
    let inicio = new Date(2022, 5, 6);
    let ahora = new Date();

    let diff = ahora - inicio;

    let dias = Math.floor(diff / (1000*60*60*24));
    let horas = Math.floor((diff/(1000*60*60)) % 24);
    let min = Math.floor((diff/(1000*60)) % 60);
    let seg = Math.floor((diff/1000) % 60);

    document.getElementById("contador").innerHTML =
        `${dias} días ${horas}h ${min}m ${seg}s juntos ❤️`;
}

// ESCRITURA
function escribir(id,texto){
    let i=0;
    let el=document.getElementById(id);
    function t(){
        if(i<texto.length){
            el.innerHTML+=texto[i];
            i++;
            setTimeout(t,20);
        }
    }
    t();
}

// PARTICULAS
function crearParticulas(){
    let emojis=["🌻","🌹","💖"];
    for(let i=0;i<40;i++){
        let e=document.createElement("div");
        e.classList.add("particle");
        e.innerHTML=emojis[Math.floor(Math.random()*3)];
        e.style.left=Math.random()*100+"vw";
        e.style.fontSize=(15+Math.random()*20)+"px";
        e.style.animationDuration=(6+Math.random()*6)+"s";
        document.body.appendChild(e);
    }
}

// GALERIA
let index=0;
function iniciarGaleria(){
    let images=document.querySelectorAll(".gallery img");
    function cambiar(){
        images.forEach(img=>img.classList.remove("active"));
        images[index].classList.add("active");
        index=(index+1)%images.length;
    }
    cambiar();
    setInterval(cambiar,3000);
}

// AUDIO
function fadeInAudio(audio){
    audio.volume=0;
    audio.play().catch(()=>{});
    let v=0;
    let i=setInterval(()=>{
        if(v<1){ v+=0.02; audio.volume=v; }
        else clearInterval(i);
    },200);
}

// CORAZONES CLICK
function corazonesClick(x,y){
    for(let i=0;i<10;i++){
        let h=document.createElement("div");
        h.innerHTML="🖤";
        h.style.position="fixed";
        h.style.left=x+"px";
        h.style.top=y+"px";

        let dx=(Math.random()-0.5)*100;
        let dy=Math.random()*-150;

        h.animate([
            {transform:"translate(0,0)",opacity:1},
            {transform:`translate(${dx}px,${dy}px)`,opacity:0}
        ],{duration:1000});

        document.body.appendChild(h);
        setTimeout(()=>h.remove(),1000);
    }
}

// INICIAR
function iniciar(){
    document.querySelector(".start-btn").style.display="none";
    document.getElementById("contenido").style.display="block";

    let meses = calcularMeses();
    document.getElementById("titulo").innerHTML =
        "Feliz " + meses + " meses juntos mi princesita ❤️";

    let audio=document.getElementById("musica");
    fadeInAudio(audio);

    crearParticulas();
    escribir("text1",texto1);
    setTimeout(()=>escribir("text2",texto2),2000);
    iniciarGaleria();

    setInterval(actualizarContador,1000);
}

document.querySelector(".start-btn").addEventListener("click",(e)=>{
    corazonesClick(e.clientX,e.clientY);
});
</script>

</body>
</html>
