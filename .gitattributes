<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Para mi Princesita 🌻❤️</title>

<style>
body {
    margin: 0;
    padding: 0;
    font-family: Arial;
    color: white;
    text-align: center;

    /* 🔥 FONDO FINAL CORREGIDO */
    background: url("Snoopy.jpg") no-repeat center center fixed;
    background-size: cover;

    overflow-x: hidden;
}

/* BOTÓN */
.start-btn {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    
    width: 80%;
    max-width: 400px;
    padding: 25px;

    background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("Snoopy.jpg");
    background-size: cover;
    background-position: center;

    color: white;
    font-size: 18px;
    border-radius: 20px;
    cursor: pointer;
    z-index: 9999;

    box-shadow: 0 0 25px rgba(255,0,0,0.7);
    border: 2px solid red;
}

/* CONTENIDO */
#contenido {
    display: none;
    animation: fade 2s;
}

@keyframes fade {
    from {opacity:0;}
    to {opacity:1;}
}

.container {
    display: flex;
    justify-content: space-around;
    padding: 20px;
}

/* TEXTO */
.box {
    width: 40%;
    background: rgba(0,0,0,0.4);
    padding: 20px;
    border-radius: 15px;
}

/* VIDEO */
.video-box {
    width: 40%;
}

/* 🌻🌹💖 PARTÍCULAS */
.particle {
    position: fixed;
    top: -10%;
    animation: caer linear infinite;
    opacity: 0.8;
}

@keyframes caer {
    0% { transform: translateY(-10%) translateX(0) rotate(0deg); }
    100% { transform: translateY(110vh) translateX(30px) rotate(360deg); }
}

/* 📸 GALERÍA */
.gallery {
    width: 300px;
    height: 300px;
    margin: 30px auto;
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}

.gallery img {
    position: absolute;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain; /* 🔥 centradas sin recorte */
    object-position: center;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
}

.gallery img.active {
    opacity: 1;
}

/* RESPONSIVE */
@media (max-width:768px){
    .container {
        flex-direction: column;
        align-items: center;
    }
    .box, .video-box {
        width: 90%;
        margin-bottom: 20px;
    }
}
</style>
</head>

<body>

<div class="start-btn" onclick="iniciar()">
🖤 Feliz mesiversario mi princesita, toca aquí 😉 🖤
</div>

<audio id="musica" loop>
  <source src="I love you song.mp3" type="audio/mpeg">
</audio>

<div id="contenido">

<h1 id="titulo" class="titulo-animado"></h1>

<div class="gallery">
  <img src="imagen1.jpeg">
  <img src="imagen2.jpeg">
  <img src="imagen3.jpeg">
  <img src="imagen4.jpeg">
  <img src="imagen5.jpeg">
  <img src="imagen6.jpeg">
  <img src="imagen7.jpeg">
  <img src="imagen8.jpeg">
</div>

<div class="container">

    <div class="box">
        <p id="text1"></p>
        <p id="text2"></p>
    </div>

    <div class="video-box">
        <video id="video" controls width="100%">
            <source src="video.mp4" type="video/mp4">
        </video>
    </div>

</div>

</div>

<script>
// TEXTOS
let texto1 = `Hoy cumplimos otro mes más juntos ❤️
y no sabes lo feliz que soy de tenerte en mi vida.
Cada momento contigo es especial, cada recuerdo contigo vale oro...`;

let texto2 = `Gracias por estar conmigo, por tu amor, tu paciencia
y por hacerme sentir el chico más afortunado del mundo.
Te amo muchísimo mi princesita 🖤`;

// ESCRITURA
function escribir(id,texto){
    let i=0;
    let el=document.getElementById(id);
    function t(){
        if(i<texto.length){
            el.innerHTML+=texto[i];
            i++;
            setTimeout(t,10);
        }
    }
    t();
}

// 🌻🌹🥰🐣 PARTÍCULAS
function crearParticulas(){
    let emojis=["🌻","🌹","💖"];
    for(let i=0;i<50;i++){
        let e=document.createElement("div");
        e.classList.add("particle");
        e.innerHTML=emojis[Math.floor(Math.random()*emojis.length)];

        e.style.left=Math.random()*100+"vw";
        e.style.fontSize=(15+Math.random()*25)+"px";
        e.style.animationDuration=(6+Math.random()*6)+"s";
        e.style.opacity=Math.random();

        document.body.appendChild(e);
    }
}

// 📸 GALERÍA
let index = 0;
let images;

function iniciarGaleria(){
    images = document.querySelectorAll(".gallery img");

    function cambiar(){
        images.forEach(img => img.classList.remove("active"));
        images[index].classList.add("active");
        index = (index + 1) % images.length;
    }

    cambiar();
    setInterval(cambiar, 3000);
}

// 🎵 MÚSICA SUAVE
function fadeInAudio(audio){
    audio.volume = 0;
    audio.play().catch(()=>{});

    let vol = 0;
    let interval = setInterval(()=>{
        if(vol < 1){
            vol += 0.02;
            audio.volume = vol;
        } else {
            clearInterval(interval);
        }
    }, 200);
}

// INICIO
function iniciar(){
    document.querySelector(".start-btn").style.display = "none";
    document.getElementById("contenido").style.display = "block";

    let audio = document.getElementById("musica");
    fadeInAudio(audio);

    let video = document.getElementById("video");
    if(video){
        video.play().catch(()=>{});
    }

    crearParticulas();
    escribir("text1", texto1);
    setTimeout(()=>escribir("text2", texto2),2000);

    iniciarGaleria();
}

.titulo-animado {
    color: red;
    -webkit-text-stroke: 1px black;
    opacity: 0;
    transform: translateX(-100px);
    animation: aparecerIzq 2s forwards;
}

@keyframes aparecerIzq {
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

function corazonesClick(x, y){
    for(let i=0;i<10;i++){
        let h = document.createElement("div");
        h.innerHTML = "🖤";
        h.style.position = "fixed";
        h.style.left = x + "px";
        h.style.top = y + "px";
        h.style.fontSize = "20px";
        h.style.pointerEvents = "none";

        let dx = (Math.random() - 0.5) * 100;
        let dy = Math.random() * -150;

        h.animate([
            {transform: "translate(0,0)", opacity:1},
            {transform: `translate(${dx}px, ${dy}px)`, opacity:0}
        ], {
            duration: 1000
        });

        document.body.appendChild(h);

        setTimeout(()=>h.remove(),1000);
    }
}

document.querySelector(".start-btn").addEventListener("click", (e)=>{
    corazonesClick(e.clientX, e.clientY);
});

</script>

</body>
</html>
